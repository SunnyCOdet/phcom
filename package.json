{
  "name": "pcphone",
  "version": "1.0.1",
  "description": "pcphone — control your PC from any phone over the web",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist:linux": "electron-builder --linux"
  },
  "author": {
    "name": "sunny",
    "email": "egnanadeep@gmail.com"
  },
  "license": "MIT",
  "build": {
    "appId": "com.sunny.pcphone",
    "productName": "pcphone",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "package.json",
      "!**/test-*.js",
      "!**/*.log",
      "!**/.env"
    ],
    "asar": true,
    "asarUnpack": [
      "**/*.node",
      "node_modules/sharp/**",
      "node_modules/@img/**",
      "node_modules/sqlite3/**",
      "node_modules/@nut-tree-fork/**",
      "node_modules/screenshot-desktop/**",
      "src/public/**"
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.utilities"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility"
    }
  },
  "dependencies": {
    "@ngrok/ngrok": "^1.7.0",
    "@nut-tree-fork/nut-js": "^4.2.6",
    "bonjour-service": "^1.4.1",
    "express": "^5.2.1",
    "localtunnel": "^2.0.2",
    "multer": "^1.4.5-lts.2",
    "qrcode": "^1.5.4",
    "screenshot-desktop": "^1.15.4",
    "sharp": "^0.33.5",
    "sqlite3": "^6.0.1",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "electron": "^35.7.5",
    "electron-builder": "^25.1.8"
  }
}
